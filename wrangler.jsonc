{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tray-hub",
  "main": "src/index.js",
  "compatibility_date": "2026-07-16",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "ALLOWED_ORIGIN": "https://cati.me",
    "ASSET_CACHE_SECONDS": "86400"
  }
}
